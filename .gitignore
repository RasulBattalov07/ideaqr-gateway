# Build output
target/
*.jar.original

# Local H2 database (runtime data — never commit). The binary DB stays ignored, but the
# folder's _INFO.md IS tracked: it's the client-facing description of the seeded demo data.
data/*
!data/_INFO.md

# Logs
*.log

# OS / editor noise
.DS_Store

# IDE project files (workspace + shelved patches must never be published — audit 3.11)
.idea/

# Whole-source export artifact — easy way to accidentally leak the codebase (audit 4.10)
IDEAQR_PROJECT_BUNDLE.txt

# Customer requirement / patent source documents — kept local, NOT published to the remote
zakazdar/
